{
  "entities": {
    "MenuItem": {
      "title": "Menu Item",
      "description": "An item offered in the cafe menu",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the menu item"
        },
        "description": {
          "type": "string",
          "description": "Description of the menu item"
        },
        "category": {
          "type": "string",
          "description": "Category of the item (e.g., coffee, sweets, cold drinks)"
        },
        "image": {
          "type": "string",
          "description": "Image URL or Base64 of the menu item"
        },
        "featured": {
          "type": "boolean",
          "description": "Whether the item is featured"
        },
        "sizes": {
          "type": "array",
          "description": "Available sizes and prices"
        }
      },
      "required": ["name", "category", "sizes"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a customer",
      "type": "object",
      "properties": {
        "orderId": {
          "type": "string",
          "description": "Human readable order ID (ORD-XXXX)"
        },
        "customerName": {
          "type": "string",
          "description": "Name of the customer"
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the customer"
        },
        "address": {
          "type": "string",
          "description": "Address of the customer"
        },
        "notes": {
          "type": "string",
          "description": "Customer notes"
        },
        "items": {
          "type": "array",
          "description": "List of items in the order"
        },
        "totalPrice": {
          "type": "number",
          "description": "Total price of the order"
        },
        "status": {
          "type": "string",
          "description": "Current status of the order (new, preparing, delivered, canceled)",
          "enum": ["new", "preparing", "delivered", "canceled"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Time when the order was placed"
        },
        "paymentMethod": {
          "type": "string",
          "description": "Payment method chosen (shamcash, subscription)"
        },
        "shamCashReceipt": {
          "type": "string",
          "description": "If shamcash: the transfer transaction id / receipt number"
        },
        "subscriptionCode": {
          "type": "string",
          "description": "If subscription_code: the used subscription code"
        }
      },
      "required": ["customerName", "phone", "address", "items", "totalPrice", "status"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "A subscription code generated by the admin for a customer",
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "Unique subscription code"
        },
        "ownerName": {
          "type": "string",
          "description": "The subscriber's full name"
        },
        "contact": {
          "type": "string",
          "description": "The contact details like phone number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Time when this code was created"
        }
      },
      "required": ["code", "ownerName", "contact"]
    }
  },
  "firestore": {
    "/menu/{itemId}": {
      "schema": "MenuItem",
      "description": "Collection of available menu items"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of placed orders"
    },
    "/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "Collection of subscription codes"
    },
    "/admin_accounts/{accountId}": {
      "description": "Collection of admin accounts"
    },
    "/settings/{settingId}": {
      "description": "Collection of settings (e.g. shamcash merchant account ID)"
    }
  }
}
